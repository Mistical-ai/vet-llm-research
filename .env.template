# OVC Pet Trust LLM Research — environment template
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and edit values there. Never commit .env.
#   Windows:       copy .env.template .env
#   macOS/Linux:   cp .env.template .env
#
# All pipeline scripts load .env at startup via python-dotenv. Change a value
# here, mirror it in your local .env, and re-run the script — no code edits.
#
# HOW TO READ THIS FILE
#   Every setting has a short comment directly above it explaining what it
#   does, when to touch it, and what happens if you don't. Settings that have
#   more than one sensible value show a "menu" of ready-to-use lines — copy
#   the one you want into .env, or just uncomment it here. Only one line per
#   setting should ever be active (uncommented) at a time.
#
# TABLE OF CONTENTS (search for the ── banner text to jump to a section)
#   1. Safety & Budget Controls .......... DRY_RUN, BUDGET_HARD_STOP
#   2. Corpus Collection (Phase 2) ....... CrossRef/Unpaywall candidate search
#   3. Rate Limits & Retries ............. API pacing, backoff
#   4. Balanced Corpus Download .......... download pacing, failure thresholds
#   5. PDF Text Validation Gate .......... minimum page/section/word gates
#   6. PDF Text Extraction ............... column handling, output folder
#   7. Article-Type Filtering ............ exclude/flag non-primary-research
#   8. Prompt Configuration (Phase 3) .... which prompt each provider gets
#   9. Evaluation Rubric & Identifiers ... which judge rubric, benchmark tags
#  10. Phase 3 Run Mode ................. test / single / dev / batch
#  11. summarize-all Workflow ........... comparison-run output controls
#  12. Batch API Availability ........... per-provider batch toggles
#  13. Scientific Reproducibility ....... temperature, seed, token caps
#  14. Judge Configuration & Jury Score . how many judges, weighted vs flat
#  15. Journal-Stratified Sampling ...... single/dev mode sampling seed
#  16. Model IDs ......................... which model each provider calls
#  17. Scenarios & Offline Rubric ........ pipeline.py --use-rubric (Phase 4)
#  18. API Keys .......................... secrets — never commit these


# ═══════════════════════════════════════════════════════════════════════════
# 1. Safety & Budget Controls
# ═══════════════════════════════════════════════════════════════════════════

# DRY_RUN is the master safety switch for the WHOLE pipeline (Phase 2 and
# Phase 3 alike): true = mock data, no network calls, $0 spend, always safe.
# false = real CrossRef/Unpaywall queries and real paid LLM calls.
#
#   DRY_RUN=true     # safe default — mock data, no network, no cost
#   DRY_RUN=false    # real network calls and real API spend
DRY_RUN=true

# Hard budget ceiling in USD. BudgetGuard calls sys.exit() the moment total
# spend would exceed this value, so a runaway loop can never overspend past
# this number. Keep at 0.00 whenever DRY_RUN=true or you're only doing
# Phase 2 ingestion (no LLM calls = $0 cost regardless).
BUDGET_HARD_STOP=0.00


# ═══════════════════════════════════════════════════════════════════════════
# 2. Corpus Collection (Phase 2: CrossRef / Unpaywall search)
# ═══════════════════════════════════════════════════════════════════════════

# Your institutional email address. Required by Unpaywall and CrossRef's
# "polite pool" for faster, more reliable API access. This is NOT a secret —
# it just identifies you as a researcher to those services.
UNPAYWALL_EMAIL=your.name@uoguelph.ca

# Number of CrossRef DOI candidates to collect per journal before downloading.
# Default 1000 = up to 5000 candidates total across the 5 target journals.
# The downloader still stops at 50 accepted PDFs per journal regardless of
# how many candidates were collected.
COLLECT_CANDIDATES_PER_JOURNAL=1000

# Query each year separately so the manifest covers all years evenly instead
# of filling only from the newest CrossRef results.
#   COLLECT_YEAR_BALANCED=true    # spread candidates evenly across COLLECT_YEARS
#   COLLECT_YEAR_BALANCED=false   # take CrossRef's default (newest-first) ordering
# Range: 2023–2026 (including the current year captures recent OA deposits).
COLLECT_YEAR_BALANCED=true
COLLECT_YEARS=2023,2024,2025,2026

# Optional: query Unpaywall during collection and add OA metadata/ranking
# fields to the manifest. Leave "require OA" strict mode false unless you
# want to exclude papers with no known OA locations before the downloader
# even tries them.
COLLECT_PREFLIGHT_UNPAYWALL=false
COLLECT_REQUIRE_UNPAYWALL_OA=false
COLLECT_MIN_OA_LOCATIONS=1
COLLECT_PREFER_DIRECT_PDF=true

# COLLECT_EXCLUDE_TYPES (optional): comma-separated phrases checked at
# collection time in collect.py. If a CrossRef title begins with one of
# these phrases, the DOI is excluded from manifest.jsonl before download.
# Leave empty to rely only on PDF-side filtering via
# EXCLUDE_ARTICLE_TYPE_PATTERNS below (section 7).
COLLECT_EXCLUDE_TYPES=


# ═══════════════════════════════════════════════════════════════════════════
# 3. Rate Limits & Retries
# ═══════════════════════════════════════════════════════════════════════════

# Seconds to wait between API calls for each model (prevents HTTP 429 errors).
# Increase these values if you see rate-limit errors during Phase 3.
RATE_LIMIT_GEMINI=1.0
RATE_LIMIT_OPENAI=1.0
RATE_LIMIT_ANTHROPIC=1.0
RATE_LIMIT_DEFAULT=1.0

# OpenAI rate-limit retry config (applies only when HTTP 429 is received).
# The inner backoff layer retries up to MAX_RETRIES times before propagating.
# Formula: delay = min(BASE_DELAY * 2^attempt + jitter(0,1), MAX_DELAY)
# Increase MAX_RETRIES or MAX_DELAY if you are on a low tier with slow resets.
OPENAI_MAX_RETRIES=6
OPENAI_RETRY_BASE_DELAY=1.0
OPENAI_RETRY_MAX_DELAY=60.0


# ═══════════════════════════════════════════════════════════════════════════
# 4. Balanced Corpus Download Controls (Phase 2)
# ═══════════════════════════════════════════════════════════════════════════

# Minimal console output by default: progress bar + one line per
# success/failure only.
#   DOWNLOAD_VERBOSE=false   # quiet — recommended for normal runs
#   DOWNLOAD_VERBOSE=true    # also prints "Trying OA sources for DOI: ..." and
#                            # "Already exists, skipping" — useful when
#                            # debugging a single paper
# All failures are still written to data/error_log.jsonl regardless of this flag.
DOWNLOAD_VERBOSE=false

# Maximum number of failed download attempts allowed per journal before the
# journal is flagged for manual supplementation and skipped.
# Default 300 balances runtime vs coverage for large candidate manifests.
MAX_FAILED_PER_JOURNAL=300

# Per-journal Cloudflare / HTTP 403 tally (seeded from data/error_log.jsonl).
# When reached, remaining manifest rows skip automation with reason
# CLOUDFLARE_BLOCKED instead of retrying a source that's actively blocking you.
MANUAL_ONLY_THRESHOLD=10

# Seconds to pause between each OA fallback attempt for a single DOI.
# Prevents HTTP 429 rate-limit errors from Unpaywall, Semantic Scholar, and NCBI.
#   DOWNLOAD_DELAY_SECONDS=2   # default — safe on campus and off
#   DOWNLOAD_DELAY_SECONDS=0   # only if you're off-campus and want max speed
DOWNLOAD_DELAY_SECONDS=2

# Publisher-facing requests (Wiley, AVMA, SAGE) should be slower than API
# requests because they go through human-facing journal websites and CDN
# bot/rate-limit systems. The downloader picks a random value in this range
# before each publisher request.
#   10–25   # default — safe pacing for publisher sites
#   0–0     # only for single-DOI debugging
PUBLISHER_DELAY_MIN_SECONDS=10
PUBLISHER_DELAY_MAX_SECONDS=25

# If a server returns HTTP 429 without a Retry-After header, wait this many
# seconds before continuing. If Retry-After IS provided, the script obeys
# that value instead.
RATE_LIMIT_BACKOFF_SECONDS=60


# ═══════════════════════════════════════════════════════════════════════════
# 5. PDF Text Validation Gate (Phase 2)
# ═══════════════════════════════════════════════════════════════════════════

# MIN_PAGES: reject short PDFs before full text extraction.
# MIN_SECTIONS: minimum count of matched section categories (introduction /
# methods / results / discussion / conclusion), each detected by synonym
# regex in SECTION_PATTERNS — not by matching one fixed header spelling.
# MIN_EXTRACTED_WORDS remains the hard final gate after references stripping.
MIN_PAGES=3
MIN_SECTIONS=3
MIN_EXTRACTED_WORDS=3000
TARGET_EXTRACTED_WORDS=4500
MIN_EXTRACTED_TOKENS=4000

# Leave false for real runs. Set true only in narrow unit tests that exercise
# downloader plumbing without constructing real PDFs.
SKIP_VALIDATION_FOR_TESTING=false


# ═══════════════════════════════════════════════════════════════════════════
# 6. PDF Text Extraction (Phase 3)
# ═══════════════════════════════════════════════════════════════════════════

# Leave true for two-column journals (JVIM, VRU): pdfplumber/pdfminer then
# follows text flow more carefully instead of interleaving left and right
# columns. If your installed pdfplumber is too old, the code logs a warning
# and falls back to tight character-based grouping.
PDFPLUMBER_USE_TEXT_FLOW=true

# Extraction output/input folder name under data/. All pipeline stages
# (extract, summarize, evaluate, status) follow this setting, so changing
# it switches the WHOLE pipeline to a different text source at once.
#   PROCESSED_DIR_NAME=processedv2   # recommended — pymupdf4llm Markdown
#                                     # extractions (structured, tables kept)
#   PROCESSED_DIR_NAME=processed     # original pdfplumber extractions
#                                     # (plain text, whitespace artifacts)
# After changing this value, run: python llm-sum/prepare_texts.py --all
# to populate the new folder before summarizing/evaluating against it.
PROCESSED_DIR_NAME=processedv2

# Strip the References section during PDF extraction before caching text.
# Keep true so MAX_INPUT_CHARS limits (section 13) preserve Results/
# Discussion content instead of being eaten by a long bibliography.
REMOVE_REFERENCES=true

# Warn in prepare_texts.py when a cached article falls below this word count.
MIN_WORD_COUNT_WARN=1000


# ═══════════════════════════════════════════════════════════════════════════
# 7. Article-Type Filtering
# ═══════════════════════════════════════════════════════════════════════════

# EXCLUDE_ARTICLE_TYPE_PATTERNS: comma-separated phrases that identify non-
# primary-research articles. If any phrase appears in the first two pages of
# a downloaded PDF, the PDF is deleted and the DOI is logged as
# NON_RESEARCH_TYPE. These article types do NOT count toward the 50-paper
# per-journal quota.
#
# WHY CHECK THE PDF AND NOT JUST THE METADATA?
#   CrossRef often lacks structured article-type fields. Veterinary journals
#   reliably print labels like "Short Communication" or "Case Report" at the
#   top of the first page, so reading the PDF is more reliable.
#
# COLLECT_EXCLUDE_TYPES (section 2, optional): the same phrases are also
# checked at collection time in collect.py. If a CrossRef title begins with
# one of these phrases (e.g. "Case Report: Spontaneous X in a cat"), the DOI
# is excluded from manifest.jsonl entirely, saving a download attempt.
EXCLUDE_ARTICLE_TYPE_PATTERNS=short communication,brief communication,brief report,case report,case series,case study,imaging diagnosis,imaging findings,rapid communication

# SECONDARY_ARTICLE_TYPE_PATTERNS: phrases that identify secondary research
# (literature reviews, syntheses of existing studies). These ARE downloaded
# but saved with a "2_" filename prefix so they are easy to find and can be
# excluded from LLM analysis if needed. They do NOT count toward the
# primary-research quota.
#
# In pipeline.py, secondary papers are listed separately from primary papers
# so you always know your exact primary vs secondary breakdown.
SECONDARY_ARTICLE_TYPE_PATTERNS=systematic review,meta-analysis,scoping review,narrative review


# ═══════════════════════════════════════════════════════════════════════════
# 8. Prompt Configuration (Phase 3: Summariser)
# ═══════════════════════════════════════════════════════════════════════════

# PROMPT_MODE controls whether all three providers get the exact same prompt,
# or each gets its own file:
#   PROMPT_MODE=shared             # recommended — keeps the study baseline
#                                   # fair: OpenAI, Anthropic, and Gemini all
#                                   # receive PROMPT_FILE verbatim
#   PROMPT_MODE=provider_specific  # prompt-engineering experiments only —
#                                   # lets you edit one provider's
#                                   # instructions without changing the others
# Every prompt file must keep the {ARTICLE_TEXT} placeholder, whichever mode
# is active.
PROMPT_MODE=shared

# Paths are relative to the repo root.
PROMPT_FILE=llm-sum/prompts/summarization_v1.txt
OPENAI_PROMPT_FILE=llm-sum/prompts/summarization_openai_v1.txt
ANTHROPIC_PROMPT_FILE=llm-sum/prompts/summarization_anthropic_v1.txt
GEMINI_PROMPT_FILE=llm-sum/prompts/summarization_gemini_v1.txt

# Optional human-written format guide appended to the summarisation prompt.
GUIDE_SUMMARY_FILE=llm-sum/prompts/guide_summary_template.txt


# ═══════════════════════════════════════════════════════════════════════════
# 9. Evaluation Rubric & Identifiers (Phase 3: Judge)
# ═══════════════════════════════════════════════════════════════════════════

# JUDGE_PROMPT_FILE selects the rubric the blind judge scores against.
# Keep this fixed for all runs you want to compare directly — switching mid-
# study makes jury_score values from before/after incomparable.
#   JUDGE_PROMPT_FILE=llm-sum/prompts/judge_medhelm_v1.txt  # current default —
#                                   # MedHELM-style: criterion-level jury
#                                   # scoring, source-quoted hallucination
#                                   # checks, no summariser model names in
#                                   # the judge prompt
#   JUDGE_PROMPT_FILE=llm-sum/prompts/judge_v2.txt   # legacy — Vet-Score v2.0
#                                   # four-dimension rubric (sensitivity
#                                   # analysis only)
#   JUDGE_PROMPT_FILE=llm-sum/prompts/judge_v1.txt   # legacy — generic 1-10
#                                   # rubric (sensitivity analysis only)
JUDGE_PROMPT_FILE=llm-sum/prompts/judge_medhelm_v1.txt

# Evaluation-method identifiers written into data/evaluations.jsonl. These
# are not secrets; they make it obvious which benchmark/rubric produced each
# row. Change them only when the rubric, weights, or row schema meaningfully
# changes — a new value here marks a clean break from prior scores.
EVAL_BENCHMARK_NAME=vet_lit_summary_medhelm
EVAL_RUBRIC_VERSION=vet_medhelm_score_v1.0
EVALUATOR_VERSION=evaluator-medhelm-v1.0


# ═══════════════════════════════════════════════════════════════════════════
# 10. Phase 3 Run Mode
# ═══════════════════════════════════════════════════════════════════════════

# PHASE3_MODE is the single knob controlling what summarizer/evaluator do.
# Pick one and the rest of the behaviour follows automatically. CLI --mode
# and --limit on any Phase 3 script override these values for one run
# without editing .env.
#
#   PHASE3_MODE=test     # DRY_RUN, no API calls, mock data. Default. Used by
#                         # pytest. Safe to leave here forever; no spend possible.
#   PHASE3_MODE=single   # 1 matched article, real-time API. For
#                         # summarize-all this means the same DOI/title from
#                         # data/raw and data/processed: 1 raw PDF x 3
#                         # providers + 1 processed text x 3 providers = 6
#                         # summaries total. Use this as the paid smoke test.
#   PHASE3_MODE=dev      # PHASE3_DEV_LIMIT papers (default 5), real-time,
#                         # budget-guarded. For summarize-all, dev uses
#                         # PHASE3_DEV_LIMIT matched DOI/title pairs from
#                         # data/raw and data/processed. With the default 5:
#                         # 5 articles x 2 source types x 3 providers = 30
#                         # summaries.
#   PHASE3_MODE=batch    # Full corpus, Batch API (50% off where supported).
#                         # Requires interactive 'yes' confirmation at the
#                         # prompt. Note: summarize-all does not support
#                         # batch because direct PDF upload is real-time
#                         # only; use batch only for manifest/text workflows.
PHASE3_MODE=test
PHASE3_DEV_LIMIT=5


# ═══════════════════════════════════════════════════════════════════════════
# 11. summarize-all Workflow (comparison-run output controls)
# ═══════════════════════════════════════════════════════════════════════════

# Picks matched PDF/processed article pairs for the summarize-all comparison.
#   SUMMARIZE_ALL_RANDOM_MATCH=false   # default — same first sorted matched
#                                       # article(s) every run (reproducible)
#   SUMMARIZE_ALL_RANDOM_MATCH=true    # pick matched pairs randomly each run
SUMMARIZE_ALL_RANDOM_MATCH=false

# Controls whether repeated runs overwrite each other's output files.
#   SUMMARIZE_ALL_UNIQUE_OUTPUT=true    # default — separate timestamped file
#                                        # per run, nothing is ever overwritten:
#                                        #   data/summaries_pdf/<stem>__run_YYYYMMDDTHHMMSSffffffZ.txt
#                                        #   data/summaries_txt/<stem>__run_YYYYMMDDTHHMMSSffffffZ.txt
#   SUMMARIZE_ALL_UNIQUE_OUTPUT=false   # write data/summaries_pdf/<stem>.txt
#                                        # and data/summaries_txt/<stem>.txt,
#                                        # which CAN overwrite earlier outputs
SUMMARIZE_ALL_UNIQUE_OUTPUT=true

# Controls where readable summarize-all outputs go. CLI --output-set
# overrides this for one command without editing .env.
#   SUMMARIZE_ALL_OUTPUT_SET=auto       # default — dev mode writes to
#                                        # data/dev_tests/; test/single use
#                                        # the regular output folders
#   SUMMARIZE_ALL_OUTPUT_SET=regular    # always write to
#                                        # data/summaries_pdf/ and data/summaries_txt/
#   SUMMARIZE_ALL_OUTPUT_SET=dev-tests  # always write to
#                                        # data/dev_tests/summaries_pdf/ and
#                                        # data/dev_tests/summaries_txt/
SUMMARIZE_ALL_OUTPUT_SET=auto


# ═══════════════════════════════════════════════════════════════════════════
# 12. Batch API Availability (only consulted when PHASE3_MODE=batch)
# ═══════════════════════════════════════════════════════════════════════════

# Per-provider batch availability. Gemini batch is intentionally off — its
# non-batch API is fast enough that the marginal saving isn't worth the
# second code path.
OPENAI_BATCH_ENABLED=true
ANTHROPIC_BATCH_ENABLED=true
GEMINI_BATCH_ENABLED=false


# ═══════════════════════════════════════════════════════════════════════════
# 13. Scientific Reproducibility Controls
# ═══════════════════════════════════════════════════════════════════════════
# DO NOT CHANGE any value in this section between runs you want to compare —
# that's the whole point of these being fixed. Changing one intentionally
# marks a clean break; bump EVAL_RUBRIC_VERSION/EVALUATOR_VERSION (section 9)
# to make that break visible in data/evaluations.jsonl.

TEMPERATURE=0.0
SEED=42

# MAX_INPUT_CHARS applies only to pasted text inputs from data/processed/ and
# data/raw_text/. Direct PDF uploads from data/raw/ are not truncated here.
#   MAX_INPUT_CHARS=0       # recommended for processedv2 — send the full
#                            # cached text; pymupdf4llm produces structured
#                            # Markdown that all providers handle well at full
#                            # length, and full-length text ensures
#                            # Limitations/Conclusions sections are not cut off
#   MAX_INPUT_CHARS=12000   # only when debugging costs with the old
#                            # pdfplumber-extracted text
MAX_INPUT_CHARS=0

# Shared output-token cap for summariser, batch, judge, and cost-estimator
# calls. 1500 leaves room for structured summaries and judge_v2 source-quote
# responses.
MAX_OUTPUT_TOKENS=1500

# Gemini sometimes serializes structured summaries as longer JSON than the
# other SDKs. This provider-specific cap prevents "Unterminated string"
# truncation without changing OpenAI/Anthropic completion budgets.
GEMINI_MAX_OUTPUT_TOKENS=2400


# ═══════════════════════════════════════════════════════════════════════════
# 14. Judge Configuration & Jury Score Aggregation
# ═══════════════════════════════════════════════════════════════════════════

# JUDGE_MODELS: comma-separated list of provider keys to use as blind judges.
# Escalation path — uncomment one line as budget allows. Each step is a
# one-line config change; no code changes are ever needed to scale up:
#   JUDGE_MODELS=openai                      # default: 1 judge, cheapest
#   JUDGE_MODELS=openai,anthropic             # 2 judges, adds judge_disagreement
#   JUDGE_MODELS=openai,anthropic,gemini      # 3 judges: matches stock MedHELM's
#                                             # default jury panel size
JUDGE_MODELS=openai

# JURY_AGGREGATION_MODE controls which computed score becomes the primary
# `jury_score` field written to data/evaluations.jsonl. Both
# jury_score_weighted and jury_score_unweighted are ALWAYS computed and
# stored on every row regardless of this setting, so switching modes never
# requires re-running judges. See docs/phase3/medhelm_evaluation.md for the
# full comparison of the two methods.
#   JURY_AGGREGATION_MODE=unweighted   # default — stock MedHELM's flat mean
#                                       # across all criteria
#   JURY_AGGREGATION_MODE=weighted     # this project's clinical-risk-weighted
#                                       # formula (faithfulness/safety
#                                       # weighted above clarity)
JURY_AGGREGATION_MODE=unweighted

# JURY_CRITERION_WEIGHTS: optional JSON object overriding the default
# criterion weights, used only when JURY_AGGREGATION_MODE=weighted. Must
# include exactly the five criteria below or the override is ignored and
# defaults are used silently (a typo here can't corrupt every score).
#   JURY_CRITERION_WEIGHTS={"faithfulness":1.5,"completeness":1.0,"clinical_usefulness":1.2,"clarity":0.8,"safety":1.3}
# Leave blank to use the defaults shown above.
JURY_CRITERION_WEIGHTS=


# ═══════════════════════════════════════════════════════════════════════════
# 15. Journal-Stratified Sampling (Phase 3.5: single/dev mode evaluation)
# ═══════════════════════════════════════════════════════════════════════════

# Fixed seed ensures the same 5 articles (1 per journal) are always selected
# in single/dev mode, making runs reproducible and auditable.
# Change only if you intentionally want a different random draw.
EVAL_SAMPLE_SEED=42


# ═══════════════════════════════════════════════════════════════════════════
# 16. Model IDs (Phase 3: which model each provider calls)
# ═══════════════════════════════════════════════════════════════════════════

# HOW THE CLIENTS WORK:
#   The Python code loads this .env file once at startup, then creates
#   provider clients only when that provider is actually called:
#
#     OpenAI    -> openai.OpenAI()
#     Anthropic -> anthropic.Anthropic()
#     Gemini    -> google.genai.Client()
#
#   The model IDs below are then read with os.getenv(...) and passed to those
#   clients. Keeping model names here instead of hardcoding them in Python
#   makes it easy to update models without editing the pipeline logic.
#
# These must be the exact API model identifiers accepted by each provider.
# Requested lineup:
#   OpenAI    = ChatGPT/GPT 5.4
#   Anthropic = Claude Sonnet 4.6
#   Gemini    = Gemini 3.5 Flash
OPENAI_MODEL=gpt-5.4
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-3.5-flash


# ═══════════════════════════════════════════════════════════════════════════
# 17. Scenarios & Offline Rubric (Phase 4: pipeline.py auxiliary checks)
# ═══════════════════════════════════════════════════════════════════════════

# Lightweight MedHELM-inspired checks via:  python pipeline.py --use-rubric
# Phase 3's blind jury (llm-sum/evaluator.py) remains authoritative; these
# settings only affect the FREE heuristic scorer in src/evaluation/.
#
# OFFLINE_RUBRIC_PATH: YAML rubric for keyword/heuristic scoring (rubric_v1).
#   NOT the live judge prompt — that is JUDGE_PROMPT_FILE in section 9.
# RUBRIC_SCORES_PATH: separate JSONL snapshot; never writes evaluations.jsonl.
# SUMMARIES_JSONL_PATH: which summary slots to score (usually data/summaries.jsonl).
# PROCESSED_DIR_NAME (section 6) is reused for reference-text lookup:
#   processed full text > manifest abstract > manifest title.
OFFLINE_RUBRIC_PATH=docs/rubrics/rubric_v1.yaml
RUBRIC_SCORES_PATH=data/rubric_scores.jsonl
SUMMARIES_JSONL_PATH=data/summaries.jsonl


# ═══════════════════════════════════════════════════════════════════════════
# 18. API Keys (secrets — fill in only in your local .env, never here)
# ═══════════════════════════════════════════════════════════════════════════

# API keys are secrets. Put real keys in .env only. Do not commit .env.
# Uncomment the lines you need and paste your real key after the "=".
# GEMINI_API_KEY=YOUR_KEY_HERE
# ANTHROPIC_API_KEY=YOUR_KEY_HERE
# OPENAI_API_KEY=YOUR_KEY_HERE
