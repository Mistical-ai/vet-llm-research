# OVC Pet Trust LLM Research — environment template
# ═══════════════════════════════════════════════════════════════════════════
# Copy this file to .env and edit values there. Never commit .env.
#   Windows:       copy .env.template .env
#   macOS/Linux:   cp .env.template .env
#
# All pipeline scripts load .env at startup via python-dotenv. Change a value
# here, mirror it in your local .env, and re-run the script — no code edits.
#
# HOW TO READ THIS FILE
#   Every setting has a short comment directly above it explaining what it
#   does, when to touch it, and what happens if you don't. Settings that have
#   more than one sensible value show a "menu" of ready-to-use lines — copy
#   the one you want into .env, or just uncomment it here. Only one line per
#   setting should ever be active (uncommented) at a time.
#
# TABLE OF CONTENTS (search for the ── banner text to jump to a section)
#   1. Safety & Budget Controls .......... DRY_RUN, BUDGET_HARD_STOP
#   2. Corpus Collection (Phase 2) ....... CrossRef/Unpaywall candidate search
#   3. Rate Limits & Retries ............. API pacing, backoff
#   4. Balanced Corpus Download .......... download pacing, failure thresholds
#   5. PDF Text Validation Gate .......... minimum page/section/word gates
#   6. PDF Text Extraction ............... column handling, output folder
#   7. Article-Type Filtering ............ exclude/flag non-primary-research
#   8. Prompt Configuration (Phase 3) .... which prompt each provider gets
#   9. Evaluation Rubric & Identifiers ... which judge rubric, benchmark tags
#  10. Phase 3 Run Mode ................. test / single / dev / batch
#  11. summarize-all Workflow ........... comparison-run output controls
#  12. Batch API Availability ........... per-provider batch toggles
#  13. Scientific Reproducibility ....... temperature, seed, token caps
#  14. Judge Configuration & Jury Score . how many judges, weighted vs flat
#  15. Journal-Stratified Sampling ...... single/dev mode sampling seed
#  16. Model IDs ......................... which model each provider calls
#  17. Scenarios & Offline Rubric ........ pipeline.py --use-rubric (Phase 4)
#  18. Human Validation .................. export-human-review sampling (Phase 5)
#  19. Pilot Human Validation ............ export-pilot-human-review dev-pool trial (Phase 5)
#  20. Publication reporting ............. eval-report --publication, report-figures, stats-engine
#  21. API Keys .......................... secrets — never commit these


# ═══════════════════════════════════════════════════════════════════════════
# 1. Safety & Budget Controls
# ═══════════════════════════════════════════════════════════════════════════

# DRY_RUN is the master safety switch for the WHOLE pipeline (Phase 2 and
# Phase 3 alike): true = mock data, no network calls, $0 spend, always safe.
# false = real CrossRef/Unpaywall queries and real paid LLM calls.
#
#   DRY_RUN=true     # safe default — mock data, no network, no cost
#   DRY_RUN=false    # real network calls and real API spend
DRY_RUN=true

# Hard budget ceiling in USD. BudgetGuard calls sys.exit() the moment total
# spend would exceed this value, so a runaway loop can never overspend past
# this number. Keep at 0.00 whenever DRY_RUN=true or you're only doing
# Phase 2 ingestion (no LLM calls = $0 cost regardless).
BUDGET_HARD_STOP=4.5


# ═══════════════════════════════════════════════════════════════════════════
# 2. Corpus Collection (Phase 2: CrossRef / Unpaywall search)
# ═══════════════════════════════════════════════════════════════════════════

# Your institutional email address. Required by Unpaywall and CrossRef's
# "polite pool" for faster, more reliable API access. This is NOT a secret —
# it just identifies you as a researcher to those services.
UNPAYWALL_EMAIL=your.name@uoguelph.ca

# Number of CrossRef DOI candidates to collect per journal before downloading.
# Default 1000 = up to 5000 candidates total across the 5 target journals.
# The downloader still stops at 50 accepted PDFs per journal regardless of
# how many candidates were collected.
COLLECT_CANDIDATES_PER_JOURNAL=1000

# Query each year separately so the manifest covers all years evenly instead
# of filling only from the newest CrossRef results.
#   COLLECT_YEAR_BALANCED=true    # spread candidates evenly across COLLECT_YEARS
#   COLLECT_YEAR_BALANCED=false   # take CrossRef's default (newest-first) ordering
# Range: 2023–2026 (including the current year captures recent OA deposits).
COLLECT_YEAR_BALANCED=true
COLLECT_YEARS=2023,2024,2025,2026

# Optional: query Unpaywall during collection and add OA metadata/ranking
# fields to the manifest. Leave "require OA" strict mode false unless you
# want to exclude papers with no known OA locations before the downloader
# even tries them.
COLLECT_PREFLIGHT_UNPAYWALL=false
COLLECT_REQUIRE_UNPAYWALL_OA=false
COLLECT_MIN_OA_LOCATIONS=1
COLLECT_PREFER_DIRECT_PDF=true

# COLLECT_EXCLUDE_TYPES (optional): comma-separated phrases checked at
# collection time in collect.py. If a CrossRef title begins with one of
# these phrases, the DOI is excluded from manifest.jsonl before download.
# Leave empty to rely only on PDF-side filtering via
# EXCLUDE_ARTICLE_TYPE_PATTERNS below (section 7).
COLLECT_EXCLUDE_TYPES=


# ═══════════════════════════════════════════════════════════════════════════
# 3. Rate Limits & Retries
# ═══════════════════════════════════════════════════════════════════════════

# Seconds to wait between API calls for each model (prevents HTTP 429 errors).
# Increase these values if you see rate-limit errors during Phase 3.
RATE_LIMIT_GEMINI=25.0
RATE_LIMIT_OPENAI=10.0
RATE_LIMIT_ANTHROPIC=8.0
RATE_LIMIT_DEFAULT=6.0

# OpenAI rate-limit retry config (applies only when HTTP 429 is received).
# The inner backoff layer retries up to MAX_RETRIES times before propagating.
# Formula: delay = min(BASE_DELAY * 2^attempt + jitter(0,1), MAX_DELAY)
# Increase MAX_RETRIES or MAX_DELAY if you are on a low tier with slow resets.
OPENAI_MAX_RETRIES=6
OPENAI_RETRY_BASE_DELAY=1.0
OPENAI_RETRY_MAX_DELAY=60.0


# ═══════════════════════════════════════════════════════════════════════════
# 4. Balanced Corpus Download Controls (Phase 2)
# ═══════════════════════════════════════════════════════════════════════════

# Minimal console output by default: progress bar + one line per
# success/failure only.
#   DOWNLOAD_VERBOSE=false   # quiet — recommended for normal runs
#   DOWNLOAD_VERBOSE=true    # also prints "Trying OA sources for DOI: ..." and
#                            # "Already exists, skipping" — useful when
#                            # debugging a single paper
# All failures are still written to data/error_log.jsonl regardless of this flag.
DOWNLOAD_VERBOSE=false

# Maximum number of failed download attempts allowed per journal before the
# journal is flagged for manual supplementation and skipped.
# Default 300 balances runtime vs coverage for large candidate manifests.
MAX_FAILED_PER_JOURNAL=300

# Per-journal Cloudflare / HTTP 403 tally (seeded from data/error_log.jsonl).
# When reached, remaining manifest rows skip automation with reason
# CLOUDFLARE_BLOCKED instead of retrying a source that's actively blocking you.
MANUAL_ONLY_THRESHOLD=10

# Seconds to pause between each OA fallback attempt for a single DOI.
# Prevents HTTP 429 rate-limit errors from Unpaywall, Semantic Scholar, and NCBI.
#   DOWNLOAD_DELAY_SECONDS=2   # default — safe on campus and off
#   DOWNLOAD_DELAY_SECONDS=0   # only if you're off-campus and want max speed
DOWNLOAD_DELAY_SECONDS=2

# Publisher-facing requests (Wiley, AVMA, SAGE) should be slower than API
# requests because they go through human-facing journal websites and CDN
# bot/rate-limit systems. The downloader picks a random value in this range
# before each publisher request.
#   10–25   # default — safe pacing for publisher sites
#   0–0     # only for single-DOI debugging
PUBLISHER_DELAY_MIN_SECONDS=10
PUBLISHER_DELAY_MAX_SECONDS=25

# If a server returns HTTP 429 without a Retry-After header, wait this many
# seconds before continuing. If Retry-After IS provided, the script obeys
# that value instead.
RATE_LIMIT_BACKOFF_SECONDS=60


# ═══════════════════════════════════════════════════════════════════════════
# 5. PDF Text Validation Gate (Phase 2)
# ═══════════════════════════════════════════════════════════════════════════

# MIN_PAGES: reject short PDFs before full text extraction.
# MIN_SECTIONS: minimum count of matched section categories (introduction /
# methods / results / discussion / conclusion), each detected by synonym
# regex in SECTION_PATTERNS — not by matching one fixed header spelling.
# MIN_EXTRACTED_WORDS remains the hard final gate after references stripping.
MIN_PAGES=3
MIN_SECTIONS=3
MIN_EXTRACTED_WORDS=3000
TARGET_EXTRACTED_WORDS=4500
MIN_EXTRACTED_TOKENS=4000

# Leave false for real runs. Set true only in narrow unit tests that exercise
# downloader plumbing without constructing real PDFs.
SKIP_VALIDATION_FOR_TESTING=false


# ═══════════════════════════════════════════════════════════════════════════
# 6. PDF Text Extraction (Phase 3)
# ═══════════════════════════════════════════════════════════════════════════

# Leave true for two-column journals (JVIM, VRU): pdfplumber/pdfminer then
# follows text flow more carefully instead of interleaving left and right
# columns. If your installed pdfplumber is too old, the code logs a warning
# and falls back to tight character-based grouping.
PDFPLUMBER_USE_TEXT_FLOW=true

# Extraction output/input folder name under data/. All pipeline stages
# (extract, summarize, evaluate, status) follow this setting, so changing
# it switches the WHOLE pipeline to a different text source at once.
#   PROCESSED_DIR_NAME=processedv2   # recommended — pymupdf4llm Markdown
#                                     # extractions (structured, tables kept)
#   PROCESSED_DIR_NAME=processed     # original pdfplumber extractions
#                                     # (plain text, whitespace artifacts)
# After changing this value, run: python llm-sum/prepare_texts.py --all
# to populate the new folder before summarizing/evaluating against it.
#
# IMPORTANT: this is the ONE setting that decides which folder `summarize`
# reads from — for EVERY mode, including PHASE3_MODE=dev and
# PHASE3_MODE=batch. There is no separate "batch uses this folder" knob.
# Change this value once and dev/single/batch runs all follow automatically;
# `summarize` also prints the resolved path at the start of every run
# (`[phase3:summarize] processed-text source: ...`) so you can confirm which
# folder a run actually used without re-reading this file.
PROCESSED_DIR_NAME=processedv2

# Strip the References section during PDF extraction before caching text.
# Keep true so MAX_INPUT_CHARS limits (section 13) preserve Results/
# Discussion content instead of being eaten by a long bibliography.
REMOVE_REFERENCES=true

# Warn in prepare_texts.py when a cached article falls below this word count.
MIN_WORD_COUNT_WARN=1000


# ═══════════════════════════════════════════════════════════════════════════
# 7. Article-Type Filtering
# ═══════════════════════════════════════════════════════════════════════════

# EXCLUDE_ARTICLE_TYPE_PATTERNS: comma-separated phrases that identify non-
# primary-research articles. If any phrase appears in the first two pages of
# a downloaded PDF, the PDF is deleted and the DOI is logged as
# NON_RESEARCH_TYPE. These article types do NOT count toward the 50-paper
# per-journal quota.
#
# WHY CHECK THE PDF AND NOT JUST THE METADATA?
#   CrossRef often lacks structured article-type fields. Veterinary journals
#   reliably print labels like "Short Communication" or "Case Report" at the
#   top of the first page, so reading the PDF is more reliable.
#
# COLLECT_EXCLUDE_TYPES (section 2, optional): the same phrases are also
# checked at collection time in collect.py. If a CrossRef title begins with
# one of these phrases (e.g. "Case Report: Spontaneous X in a cat"), the DOI
# is excluded from manifest.jsonl entirely, saving a download attempt.
EXCLUDE_ARTICLE_TYPE_PATTERNS=short communication,brief communication,brief report,case report,case series,case study,imaging diagnosis,imaging findings,rapid communication

# SECONDARY_ARTICLE_TYPE_PATTERNS: phrases that identify secondary research
# (literature reviews, syntheses of existing studies). These ARE downloaded
# but saved with a "2_" filename prefix so they are easy to find and can be
# excluded from LLM analysis if needed. They do NOT count toward the
# primary-research quota.
#
# In pipeline.py, secondary papers are listed separately from primary papers
# so you always know your exact primary vs secondary breakdown.
SECONDARY_ARTICLE_TYPE_PATTERNS=systematic review,meta-analysis,scoping review,narrative review


# ═══════════════════════════════════════════════════════════════════════════
# 8. Prompt Configuration (Phase 3: Summariser)
# ═══════════════════════════════════════════════════════════════════════════

# PROMPT_MODE controls whether all three providers get the exact same prompt,
# or each gets its own file:
#   PROMPT_MODE=shared             # recommended — keeps the study baseline
#                                   # fair: OpenAI, Anthropic, and Gemini all
#                                   # receive PROMPT_FILE verbatim
#   PROMPT_MODE=provider_specific  # prompt-engineering experiments only —
#                                   # lets you edit one provider's
#                                   # instructions without changing the others
# Every prompt file must keep the {ARTICLE_TEXT} placeholder, whichever mode
# is active.
PROMPT_MODE=shared

# Paths are relative to the repo root.
PROMPT_FILE=llm-sum/prompts/summarization_v1.txt
OPENAI_PROMPT_FILE=llm-sum/prompts/summarization_openai_v1.txt
ANTHROPIC_PROMPT_FILE=llm-sum/prompts/summarization_anthropic_v1.txt
GEMINI_PROMPT_FILE=llm-sum/prompts/summarization_gemini_v1.txt

# Optional human-written format guide appended to the summarisation prompt.
GUIDE_SUMMARY_FILE=llm-sum/prompts/guide_summary_template.txt


# ═══════════════════════════════════════════════════════════════════════════
# 9. Evaluation Rubric & Identifiers (Phase 3: Judge)
# ═══════════════════════════════════════════════════════════════════════════

# JUDGE_PROMPT_FILE selects the rubric the blind judge scores against.
# Keep this fixed for all runs you want to compare directly — switching mid-
# study makes jury_score values from before/after incomparable.
#   JUDGE_PROMPT_FILE=llm-sum/prompts/judge_medhelm_v1.txt  # current default —
#                                   # MedHELM-style: criterion-level jury
#                                   # scoring, source-quoted hallucination
#                                   # checks, no summariser model names in
#                                   # the judge prompt
#   JUDGE_PROMPT_FILE=llm-sum/prompts/judge_v2.txt   # legacy — Vet-Score v2.0
#                                   # four-dimension rubric (sensitivity
#                                   # analysis only)
#   JUDGE_PROMPT_FILE=llm-sum/prompts/judge_v1.txt   # legacy — generic 1-10
#                                   # rubric (sensitivity analysis only)
JUDGE_PROMPT_FILE=llm-sum/prompts/judge_medhelm_v1.txt

# Evaluation-method identifiers written into data/evaluations.jsonl. These
# are not secrets; they make it obvious which benchmark/rubric produced each
# row. Change them only when the rubric, weights, or row schema meaningfully
# changes — a new value here marks a clean break from prior scores.
EVAL_BENCHMARK_NAME=vet_lit_summary_medhelm
EVAL_RUBRIC_VERSION=vet_medhelm_score_v1.0
EVALUATOR_VERSION=evaluator-medhelm-v1.0

# EVAL_INPUT_MODE: which summaries `run_phase3.py evaluate` judges.
#
# IMPORTANT — `evaluate --mode dev` ignores this setting. A dev-mode evaluate
# ALWAYS uses the folder-driven dev loop ('dev-jsonl' below) unless you pass an
# explicit --input-mode on the CLI. EVAL_INPUT_MODE only governs non-dev modes.
#
#   EVAL_INPUT_MODE=jsonl     # default — the original pipeline: data/summaries.jsonl,
#                             # written by `run_phase3.py summarize`. Nothing changes
#                             # if you leave this alone.
#   EVAL_INPUT_MODE=dev-jsonl # the folder-driven dev loop: read the readable dev
#                             # summaries in data/dev_summaries_jsonl/ (written by
#                             # `summarize --mode dev`), judge their matching
#                             # articles, and mirror the scores into
#                             # data/dev_evals_jsonl/, skipping papers already there.
#                             # This is what `evaluate --mode dev` uses automatically.
#   EVAL_INPUT_MODE=dev       # judge the readable comparison files in
#                             # data/dev_tests/summaries_txt/ (written by
#                             # `run_phase3.py summarize-all` in dev mode). A DIFFERENT
#                             # artifact from dev-jsonl — the PDF-vs-text comparison.
#   EVAL_INPUT_MODE=regular   # judge data/summaries_txt/ instead — switch to this
#                             # once you're ready to run the full corpus (e.g. all
#                             # ~250 articles) through summarize-all and evaluate.
#   EVAL_INPUT_MODE=auto      # picks dev when PHASE3_MODE=dev, regular otherwise —
#                             # so the same .env value tracks PHASE3_MODE automatically.
#
# In dev/regular/auto mode, evaluate reads ONLY the processed-text side
# (data/*/summaries_txt/) — direct-PDF comparison files in summaries_pdf/ are
# never judged. --input-mode on the CLI overrides this for a single run
# without editing .env. To restore an old behaviour for a single dev run:
#   `... evaluate --mode dev --input-mode jsonl`  # journal-stratified summaries.jsonl
#   `... evaluate --mode dev --input-mode dev`    # summarize-all dev_tests comparison
#
# How many articles dev mode evaluates: capped by PHASE3_DEV_LIMIT (section 10
# below, default 5) — the same cap `summarize`/`summarize-all` already use in
# dev mode, so "5 dev articles" is one number, not three separate settings.
# Use --limit N (or the regular mode's full-corpus default) to evaluate more.
EVAL_INPUT_MODE=jsonl

# Two more `run_phase3.py evaluate` / `eval-report` outputs, neither
# configurable via .env (fixed on purpose so PROCESSED_DIR_NAME above never
# redirects them):
#   data/run_manifests/run_manifest_<run_id>.json   written by every `evaluate`
#                                                    run — provenance (git SHA,
#                                                    dataset hash, judge model
#                                                    versions, prompt SHA-256)
#   data/results/eval_report_<UTC timestamp>.json   written by every
#                                                    `eval-report` run — the
#                                                    full aggregate report.
#                                                    Pass --no-save to skip,
#                                                    or --results-dir PATH to
#                                                    redirect for one run.


# ═══════════════════════════════════════════════════════════════════════════
# 10. Phase 3 Run Mode
# ═══════════════════════════════════════════════════════════════════════════

# PHASE3_MODE is the single knob controlling what summarizer/evaluator do.
# Pick one and the rest of the behaviour follows automatically. CLI --mode
# and --limit on any Phase 3 script override these values for one run
# without editing .env.
#
#   PHASE3_MODE=test     # DRY_RUN, no API calls, mock data. Default. Used by
#                         # pytest. Safe to leave here forever; no spend possible.
#   PHASE3_MODE=single   # 1 matched article, real-time API. For
#                         # summarize-all this means the same DOI/title from
#                         # data/raw and data/processed: 1 raw PDF x 3
#                         # providers + 1 processed text x 3 providers = 6
#                         # summaries total. Use this as the paid smoke test.
#   PHASE3_MODE=dev      # PHASE3_DEV_LIMIT papers (default 5), real-time,
#                         # budget-guarded. `summarize --mode dev` picks ONE
#                         # RANDOM PAPER PER JOURNAL (there are 5 journals in
#                         # this corpus: jvim, javma, veterinary surgery,
#                         # jfms, vru) instead of just the first 5 manifest
#                         # rows — see PHASE3_DEV_SAMPLE_SEED below for how
#                         # the "random" part is controlled. For
#                         # summarize-all, dev uses PHASE3_DEV_LIMIT matched
#                         # DOI/title pairs from data/raw and data/processed.
#                         # With the default 5: 5 articles x 2 source types
#                         # x 3 providers = 30 summaries.
#   PHASE3_MODE=batch    # Full corpus, Batch API (50% off where supported).
#                         # Requires interactive 'yes' confirmation at the
#                         # prompt. Note: summarize-all does not support
#                         # batch because direct PDF upload is real-time
#                         # only; use batch only for manifest/text workflows.
#                         # Batch reads the same PROCESSED_DIR_NAME folder as
#                         # every other mode (section 6) — nothing extra to
#                         # configure here.
PHASE3_MODE=test
PHASE3_DEV_LIMIT=5

# Which random paper gets picked from each journal when you run
# `summarize --mode dev`. Same seed in -> same 5 papers out, every time, so
# dev runs stay reproducible and comparable across days/machines. Change
# this only if you deliberately want a different random draw (e.g. to spot-
# check a different set of 5 papers).
#
# This is a DIFFERENT knob from EVAL_SAMPLE_SEED (section 15): this one
# controls which papers `summarize` spends money on BEFORE any API call;
# EVAL_SAMPLE_SEED controls which already-summarized papers `evaluate`
# re-samples for judging AFTER the fact. They usually pick the same 5 papers
# right after a fresh `summarize --mode dev` run (there's only 5 to choose
# from), but can diverge once data/summaries.jsonl accumulates more papers
# from other runs — see the comment above EVAL_SAMPLE_SEED for the full
# explanation.
PHASE3_DEV_SAMPLE_SEED=42


# ═══════════════════════════════════════════════════════════════════════════
# 11. summarize-all Workflow (comparison-run output controls)
# ═══════════════════════════════════════════════════════════════════════════

# Picks matched PDF/processed article pairs for the summarize-all comparison.
#   SUMMARIZE_ALL_RANDOM_MATCH=false   # default — same first sorted matched
#                                       # article(s) every run (reproducible)
#   SUMMARIZE_ALL_RANDOM_MATCH=true    # pick matched pairs randomly each run
SUMMARIZE_ALL_RANDOM_MATCH=true

# Controls whether repeated runs overwrite each other's output files.
#   SUMMARIZE_ALL_UNIQUE_OUTPUT=true    # default — separate timestamped file
#                                        # per run, nothing is ever overwritten:
#                                        #   data/summaries_pdf/<stem>__run_YYYYMMDDTHHMMSSffffffZ.txt
#                                        #   data/summaries_txt/<stem>__run_YYYYMMDDTHHMMSSffffffZ.txt
#   SUMMARIZE_ALL_UNIQUE_OUTPUT=false   # write data/summaries_pdf/<stem>.txt
#                                        # and data/summaries_txt/<stem>.txt,
#                                        # which CAN overwrite earlier outputs
SUMMARIZE_ALL_UNIQUE_OUTPUT=true

# Controls where readable summarize-all outputs go. CLI --output-set
# overrides this for one command without editing .env.
#   SUMMARIZE_ALL_OUTPUT_SET=auto       # default — dev mode writes to
#                                        # data/dev_tests/; test/single use
#                                        # the regular output folders
#   SUMMARIZE_ALL_OUTPUT_SET=regular    # always write to
#                                        # data/summaries_pdf/ and data/summaries_txt/
#   SUMMARIZE_ALL_OUTPUT_SET=dev-tests  # always write to
#                                        # data/dev_tests/summaries_pdf/ and
#                                        # data/dev_tests/summaries_txt/
SUMMARIZE_ALL_OUTPUT_SET=auto

# SIX DIFFERENT READABLE OUTPUT FOLDERS — easy to mix up, so here's the
# difference. (The first four are the "dev" family; the last two are the same
# renderer applied to the other two run kinds.)
#   data/dev_tests/            written by `summarize-all --mode dev` above.
#                               PDF-vs-processed-text SIDE-BY-SIDE COMPARISON:
#                               needs a matching PDF *and* processed-text
#                               file for the same article.
#   data/dev_summaries_jsonl/  written by `summarize --mode dev` (section 10).
#                               Plain readable view of the REAL dev run: the
#                               journal-random papers actually sent through
#                               data/summaries.jsonl (processedv2/raw_text
#                               only, no PDF involved). Always written after a
#                               successful dev-mode `summarize` run so you can
#                               eyeball the output before trusting the numbers.
#                               One timestamped .txt file per selected paper,
#                               one section per provider. Also the SOURCE that
#                               `evaluate --mode dev` reads to decide which
#                               papers to judge.
#                               The PARENT folder is fixed, but the leaf is
#                               selectable: `summarize --mode dev
#                               --output-subdir NAME` writes to
#                               data/dev_summaries_jsonl/NAME/ instead, and
#                               tracks its own independent "already done" pool
#                               (so a paper already summarised at the top level
#                               can be re-picked — and re-paid-for — there).
#                               IMPORTANT: readers glob *.txt NON-recursively,
#                               so a subfolder pool is invisible to `evaluate
#                               --mode dev` and to the pilot review sampler
#                               unless you point them at it explicitly with
#                               `evaluate --source-dir <path>` or
#                               `pilot_human_review --dev-summaries-dir <path>`.
#                               Both commands warn when they spot such a folder.
#   data/dev_summaries_jsonl/prose/
#                               written by the SAME `summarize --mode dev` run,
#                               for the SAME papers. The two-surface split: the
#                               top-level .txt shows the STRUCTURED BULLETS
#                               (key_methods / key_findings / limitations, each
#                               capped for readability), while prose/ shows the
#                               flowing clinician `summary_text` with a word
#                               count and an [OVER 400] flag. The prose is what
#                               the blind judge scores and what human reviewers
#                               read, and the 300-340-word budget (ceiling 400)
#                               governs ONLY that prose — not the bullet view.
#                               Deliberately in a subfolder so the top-level
#                               *.txt glob never counts the same paper twice.
#   data/dev_evals_jsonl/      written by `evaluate --mode dev`. Plain readable
#                               view of the dev JUDGE run: one .txt per judged
#                               paper (keyed by DOI slug), with a section per
#                               (summarizer, judge) showing score, hallucination
#                               count, review flag, and reasoning. Mirrors
#                               data/evaluations.jsonl for the dev papers; that
#                               JSONL stays the source of truth. Papers already
#                               here are skipped on the next dev evaluate run so
#                               the sample grows incrementally (see the guide
#                               docs/phase3/dev_evaluation_guide.md).
#   data/dev_detailEval_reports/ written by the SAME `evaluate --mode dev` run,
#                               for the SAME DOIs as data/dev_evals_jsonl/ above
#                               (always written together, never separately).
#                               The deep-dive Markdown sibling: one .md per
#                               judged paper with the article title, every
#                               judge's own score AND reasoning for each of the
#                               five criteria (not just the aggregate),
#                               individual hallucination claims, automatic text
#                               metrics, and cross-judge agreement stats for
#                               that paper. Not configurable, same incremental
#                               skip behavior as data/dev_evals_jsonl/.
#   data/single_summaries_jsonl/ written by `summarize --mode single`. Exactly
#                               the same two surfaces as
#                               data/dev_summaries_jsonl/ (bullet .txt at the
#                               top level + prose/ underneath), for the one
#                               paper that run touched. Single mode doesn't
#                               pre-select a DOI the way dev mode does, so the
#                               run works out afterwards which paper actually
#                               got a fresh provider result. A fully-resumed
#                               single run legitimately writes NOTHING here and
#                               says so.
#   data/batch_summaries_jsonl/ written by `check_batch_status.py` as each
#                               provider's batch results merge back into
#                               data/summaries.jsonl. Same two surfaces again,
#                               so the finished full-corpus run leaves every
#                               paper with a readable bullet + prose file ready
#                               for judging and human validation. Batch results
#                               merge ONE PROVIDER AT A TIME, so each file is
#                               rewritten as each provider arrives — expected,
#                               not a bug. With GEMINI_BATCH_ENABLED=false (the
#                               default), Gemini never shows up as a job here —
#                               it was already written straight into
#                               data/summaries.jsonl by the real-time fallback
#                               during `summarize --mode batch` (section 12).
#                               Its readable output still only appears here
#                               once an OpenAI/Anthropic job for the same DOI
#                               merges (the renderer re-reads the whole entry,
#                               so Gemini rides along on that write) — running
#                               check_batch_status.py is still the step that
#                               produces the files in this folder.
#
# To judge or review the single/batch folders, point the readers at them:
#   python llm-sum/run_phase3.py evaluate --mode dev \
#       --source-dir data/batch_summaries_jsonl
#   python llm-sum/pilot_human_review.py \
#       --dev-summaries-dir data/batch_summaries_jsonl


# ═══════════════════════════════════════════════════════════════════════════
# 12. Batch API Availability (only consulted when PHASE3_MODE=batch)
# ═══════════════════════════════════════════════════════════════════════════

# Per-provider batch availability.
#
# Gemini batch (Google's Batch API — ai.google.dev/gemini-api/docs/batch-mode)
# is a real, supported code path in this project: 50% off the real-time
# price, results in up to 24h. It is OFF by default because it's newer/less
# battle-tested than the OpenAI/Anthropic batch paths — flip it to true only
# after you've smoke-tested it and are comfortable trusting a 250-paper job
# to it.
#
# HOW TO SMOKE-TEST before the full run: set GEMINI_BATCH_ENABLED=true, then
#   python llm-sum/run_phase3.py summarize --mode batch --limit 2
# `--limit` caps BOTH the batch-submitted providers and the real-time
# fallback leg to the same N papers, so this is a genuine small-scale test,
# not a partial one. Then run `python llm-sum/check_batch_status.py` and
# confirm the small Gemini job actually merges cleanly into
# data/summaries.jsonl before trusting the full corpus to it. The exact
# per-request JSONL shape batch_utils.build_gemini_batch_request sends is
# inferred by analogy from Google's docs (not confirmed live) — a submission
# failure here is exactly what this smoke test is meant to catch cheaply.
#
#   GEMINI_BATCH_ENABLED=false   # default — `summarize --mode batch` still
#                                 # summarises Gemini, just via the existing
#                                 # real-time call, in the SAME command as the
#                                 # OpenAI/Anthropic batch submission. No
#                                 # separate step needed either way.
#   GEMINI_BATCH_ENABLED=true    # Gemini requests are built, uploaded, and
#                                 # submitted as a real Gemini Batch job too —
#                                 # `check_batch_status.py` polls/merges it
#                                 # exactly like the OpenAI/Anthropic jobs.
OPENAI_BATCH_ENABLED=true
ANTHROPIC_BATCH_ENABLED=true
GEMINI_BATCH_ENABLED=false


# ═══════════════════════════════════════════════════════════════════════════
# 13. Scientific Reproducibility Controls
# ═══════════════════════════════════════════════════════════════════════════
# DO NOT CHANGE any value in this section between runs you want to compare —
# that's the whole point of these being fixed. Changing one intentionally
# marks a clean break; bump EVAL_RUBRIC_VERSION/EVALUATOR_VERSION (section 9)
# to make that break visible in data/evaluations.jsonl.

TEMPERATURE=0.0
SEED=42

# MAX_INPUT_CHARS applies only to pasted text inputs from data/processed/ and
# data/raw_text/. Direct PDF uploads from data/raw/ are not truncated here.
#   MAX_INPUT_CHARS=0       # recommended for processedv2 — send the full
#                            # cached text; pymupdf4llm produces structured
#                            # Markdown that all providers handle well at full
#                            # length, and full-length text ensures
#                            # Limitations/Conclusions sections are not cut off
#   MAX_INPUT_CHARS=12000   # only when debugging costs with the old
#                            # pdfplumber-extracted text
MAX_INPUT_CHARS=0

# Shared output-token cap for summariser, batch, judge, and cost-estimator
# calls. 1500 leaves room for structured summaries and judge_v2 source-quote
# responses.
MAX_OUTPUT_TOKENS=4000

# Gemini sometimes serializes structured summaries as longer JSON than the
# other SDKs. This provider-specific cap prevents "Unterminated string"
# truncation without changing OpenAI/Anthropic completion budgets.
GEMINI_MAX_OUTPUT_TOKENS=7400


# ═══════════════════════════════════════════════════════════════════════════
# 14. Judge Configuration & Jury Score Aggregation
# ═══════════════════════════════════════════════════════════════════════════

# JUDGE_MODELS: comma-separated list of provider keys to use as blind judges.
# The DEFAULT is the full 3-judge panel — evaluation should be a real jury, not
# a single grader. Dial DOWN for cost; each step is a one-line config change and
# no code changes are ever needed:
#   JUDGE_MODELS=openai,anthropic,gemini      # DEFAULT: 3 judges, full jury.
#                                             # Enables the eval-report Reliability
#                                             # section (Krippendorff's alpha +
#                                             # pairwise agreement).
#   JUDGE_MODELS=openai,anthropic             # 2 judges, cheaper (adds
#                                             # judge_disagreement, still a jury)
#   JUDGE_MODELS=openai                       # 1 judge, cheapest, no reliability
JUDGE_MODELS=openai,anthropic,gemini

# JURY_PRESET: a one-word shortcut that expands to a judge list, so you don't
# have to retype the providers. It's an alternative to JUDGE_MODELS, and is
# overridden by an explicit --judges / JUDGE_MODELS value.
#   JURY_PRESET=panel   # the full openai,anthropic,gemini jury (3 judges) — same
#                        # as the default. The CLI flag `--jury` does the same for
#                        # a single command without editing .env.
#   JURY_PRESET=duo     # 2 judges: openai + anthropic
#   JURY_PRESET=solo    # a single openai judge (cheapest; no Reliability section)
# Leave blank to use JUDGE_MODELS above (which already defaults to the 3-judge panel).
JURY_PRESET=

# JURY_AGGREGATION_MODE controls which computed score becomes the primary
# `jury_score` field written to data/evaluations.jsonl. Both
# jury_score_weighted and jury_score_unweighted are ALWAYS computed and
# stored on every row regardless of this setting, so switching modes never
# requires re-running judges. See docs/phase3/medhelm_evaluation.md for the
# full comparison of the two methods.
#   JURY_AGGREGATION_MODE=unweighted   # default — stock MedHELM's flat mean
#                                       # across all criteria
#   JURY_AGGREGATION_MODE=weighted     # this project's clinical-risk-weighted
#                                       # formula (faithfulness/safety
#                                       # weighted above clarity)
JURY_AGGREGATION_MODE=unweighted

# JURY_CRITERION_WEIGHTS: optional JSON object overriding the default
# criterion weights, used only when JURY_AGGREGATION_MODE=weighted. Must
# include exactly the five criteria below or the override is ignored and
# defaults are used silently (a typo here can't corrupt every score).
#   JURY_CRITERION_WEIGHTS={"faithfulness":1.5,"completeness":1.0,"clinical_usefulness":1.2,"clarity":0.8,"safety":1.3}
# Leave blank to use the defaults shown above.
JURY_CRITERION_WEIGHTS=


# ═══════════════════════════════════════════════════════════════════════════
# 15. Journal-Stratified Sampling (Phase 3.5: single/dev mode evaluation)
# ═══════════════════════════════════════════════════════════════════════════

# Controls which already-summarized articles `evaluate` re-samples from
# data/summaries.jsonl for judging, in single/dev mode. Fixed seed = same
# draw every time, so runs stay reproducible and auditable.
#   single mode: 1 article per journal (5 total across the 5 journals).
#   dev mode:    up to PHASE3_DEV_LIMIT (section 10, default 5) articles
#                PER journal — so up to 25 total, not 5. This is easy to
#                mix up with `summarize --mode dev`'s PHASE3_DEV_SAMPLE_SEED
#                (also section 10), which picks exactly 1 random paper per
#                journal (5 total) BEFORE summarizing. Right after a fresh
#                `summarize --mode dev` run the two line up, because there's
#                only 5 summarized papers to sample from either way — but
#                once data/summaries.jsonl accumulates more papers from other
#                runs (single mode, batch mode, repeated dev runs), `evaluate
#                --mode dev` will sample its own — likely larger and
#                different — set from everything that's accumulated. If you
#                want evaluate to score exactly the batch you just
#                summarized, run it soon after `summarize --mode dev` on a
#                small/fresh data/summaries.jsonl, or pass explicit
#                --judges/--limit flags rather than relying on both seeds
#                to agree.
# Change EVAL_SAMPLE_SEED only if you intentionally want a different
# random draw for evaluate specifically.
EVAL_SAMPLE_SEED=42


# ═══════════════════════════════════════════════════════════════════════════
# 16. Model IDs (Phase 3: which model each provider calls)
# ═══════════════════════════════════════════════════════════════════════════

# HOW THE CLIENTS WORK:
#   The Python code loads this .env file once at startup, then creates
#   provider clients only when that provider is actually called:
#
#     OpenAI    -> openai.OpenAI()
#     Anthropic -> anthropic.Anthropic()
#     Gemini    -> google.genai.Client()
#
#   The model IDs below are then read with os.getenv(...) and passed to those
#   clients. Keeping model names here instead of hardcoding them in Python
#   makes it easy to update models without editing the pipeline logic.
#
# These must be the exact API model identifiers accepted by each provider.
# Requested lineup:
#   OpenAI    = ChatGPT/GPT 5.4
#   Anthropic = Claude Sonnet 4.6
#   Gemini    = Gemini 3.5 Flash
OPENAI_MODEL=gpt-5.4
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-3.5-flash


# ═══════════════════════════════════════════════════════════════════════════
# 17. Scenarios & Offline Rubric (Phase 4: pipeline.py auxiliary checks)
# ═══════════════════════════════════════════════════════════════════════════

# Lightweight MedHELM-inspired checks via:  python pipeline.py --use-rubric
# Phase 3's blind jury (llm-sum/evaluator.py) remains authoritative; these
# settings only affect the FREE heuristic scorer in src/evaluation/.
#
# OFFLINE_RUBRIC_PATH: YAML rubric for keyword/heuristic scoring (rubric_v1).
#   NOT the live judge prompt — that is JUDGE_PROMPT_FILE in section 9.
# RUBRIC_SCORES_PATH: separate JSONL snapshot; never writes evaluations.jsonl.
# SUMMARIES_JSONL_PATH: which summary slots to score (usually data/summaries.jsonl).
# PROCESSED_DIR_NAME (section 6) is reused for reference-text lookup:
#   processed full text > manifest abstract > manifest title.
OFFLINE_RUBRIC_PATH=docs/rubrics/rubric_v1.yaml
RUBRIC_SCORES_PATH=data/rubric_scores.jsonl
SUMMARIES_JSONL_PATH=data/summaries.jsonl



# ═══════════════════════════════════════════════════════════════════════════
# 18. Human Validation (Phase 5: python llm-sum/run_phase3.py export-human-review)
# ═══════════════════════════════════════════════════════════════════════════

# Offline only — no API calls. Samples already-judged (paper, summary) pairs
# from data/evaluations.jsonl, split EXACTLY evenly across the study's 5
# journals, and exports ONE MORE humanN/ reviewer folder (never touching an
# earlier one) so a veterinarian can score it by hand without ever seeing
# which AI system wrote which summary. All three values below can be
# overridden per-run with --sample-size / --overlap-ratio / --seed.

# How many articles to sample this run, split evenly across the study's 5
# journals — must be a multiple of 5 (5 -> 1/journal, 10 -> 2/journal, 25 ->
# 5/journal), each article expanded to ~3 providers' summaries (15/30/75
# summaries to read). Leave unset to be asked interactively at a real
# terminal (a 5/10/25 menu); a non-interactive run falls back to 5. If a
# journal's evaluated-article pool can't supply its exact share, the export
# fails loudly naming the short journal(s) rather than silently sampling
# unevenly — run more 'evaluate' first, or pick a smaller count.
# HUMAN_REVIEW_SAMPLE_SIZE=10

# Fraction of the previous tester's articles carried into the next humanN/
# folder — balanced per journal, so the carry itself never breaks the exact
# per-journal split (the rest of each journal's quota is a fresh draw).
# Spans three regimes:
#   HUMAN_REVIEW_OVERLAP_RATIO=1.0   # identical items every run
#   HUMAN_REVIEW_OVERLAP_RATIO=0.0   # a fresh, independent draw each run
#   HUMAN_REVIEW_OVERLAP_RATIO=0.6   # (default) partial overlap
HUMAN_REVIEW_OVERLAP_RATIO=0.6

# Sampling seed — same convention as EVAL_SAMPLE_SEED (section 15): a fixed
# seed makes the sample reproducible, so re-running the export (e.g. to
# regenerate a lost reviewer sheet) selects the identical items.
HUMAN_REVIEW_SEED=42

# Ingest (the next step) takes no env knobs — it is path-based only:
#   python llm-sum/run_phase3.py ingest-human-review
# reads the filled humanN/scoresheet_humanN.xlsx files + each humanN/'s
# sibling unblinding_key_human{N}.json from data/human_review/ into
# data/human_reviews.jsonl. eval-report then reports inter-reviewer agreement
# (computed over whatever items two humanN folders happen to share, via the
# overlap ratio) and human-vs-jury correlation automatically when that file
# exists. See docs/phase5/human_validation.md §7-8.

# How eval-report breaks out human-vs-jury correlation (also settable per run
# with --human-validation-mode):
#   per_reviewer  (default) — one correlation PER reviewer, so an expert (your
#                 supervising vet) is validated on their OWN scores and never
#                 diluted by averaging with a non-expert reviewer. This is the
#                 view that backs a "the jury tracks veterinarian judgment" claim.
#   pooled        — one correlation over the mean human score per item (all
#                 reviewers averaged together). Simpler, but mixes expertise.
#   both          — show both views.
HUMAN_VALIDATION_MODE=per_reviewer

# ═══════════════════════════════════════════════════════════════════════════
# 19. Pilot Human Validation (Phase 5: python llm-sum/run_phase3.py export-pilot-human-review)
# ═══════════════════════════════════════════════════════════════════════════

# Offline only — no API calls. A trial harness for the Human Validation
# workflow above: rehearse the reviewer experience (folders, guide, .xlsx
# scoresheet) against the small dev-mode sample in data/dev_summaries_jsonl/,
# before committing to the real export against the whole corpus. Each run adds
# ONE more data/pilot_human_review/humanN/ folder and never touches earlier
# ones. See docs/phase5/pilot_human_review.md. All three values below can be
# overridden per-run with --overlap-ratio / --sample-size / --seed. Unlike the
# real export, a journal that's too thin to supply its exact share is
# backfilled from other journals with a warning rather than erroring — the
# dev pool is expected to be small and still growing.

# Fraction of the previous tester's articles carried over to the next humanN/
# folder, balanced per journal (the rest are genuinely new). Spans three regimes:
#   PILOT_HUMAN_REVIEW_OVERLAP_RATIO=1.0   # identical items every run
#   PILOT_HUMAN_REVIEW_OVERLAP_RATIO=0.0   # a fresh, independent draw each run
#   PILOT_HUMAN_REVIEW_OVERLAP_RATIO=0.6   # (default) partial overlap
PILOT_HUMAN_REVIEW_OVERLAP_RATIO=0.6

# How many articles to sample this run, split evenly across the study's 5
# journals — must be a multiple of 5 (5 -> 1/journal, 10 -> 2/journal, 25 ->
# 5/journal). Leave unset to be asked interactively at a real terminal (a
# 5/10/25 menu), or to fall back to 5 on a non-interactive run.
# PILOT_HUMAN_REVIEW_SAMPLE_SIZE=5

# Base sampling seed — same convention as HUMAN_REVIEW_SEED above.
PILOT_HUMAN_REVIEW_SEED=42

# Ingest (the pilot's own next step) takes no env knobs — path-based only:
#   python llm-sum/run_phase3.py ingest-pilot-human-review
# reads the filled scoresheets from data/pilot_human_review/ into
# data/pilot_human_reviews.jsonl — the PILOT-ONLY twin of
# data/human_reviews.jsonl (section 18). It never writes to the real study
# ledger: ingest-human-review actively refuses to run against a
# data/pilot_human_review/ folder (or any export folder carrying its
# ".pilot_export" marker) so rehearsal scores can never contaminate the real
# results. Point eval-report / report-figures / stats-engine at the pilot
# file with --human-reviews data/pilot_human_reviews.jsonl to see the
# analysis rehearsed on dev-pool data. See docs/phase5/pilot_human_review.md.

# ═══════════════════════════════════════════════════════════════════════════
# 20. Publication reporting (Phase 6 — eval-report --publication)
# ═══════════════════════════════════════════════════════════════════════════
# `python llm-sum/run_phase3.py eval-report --publication` emits the paper-ready
# tables (provider comparison with 95% bootstrap CIs, paired Wilcoxon/Friedman
# significance tests, per-stratum + processed-vs-PDF breakdowns, and
# cost-per-quality-point) as JSON + Markdown + a folder of CSVs. Offline; no API
# calls. Significance tests and bootstrap CIs come from scipy.stats (pinned in
# requirements.txt); Krippendorff's alpha in reliability.py stays hand-rolled
# because scipy does not implement it. See docs/phase6/reporting.md.

# Bootstrap seed + resample count behind every confidence interval. A fixed
# seed makes each CI reproducible run-to-run; 2000 is a stable floor, raise for
# a camera-ready run or lower for a quick draft. Also used by
# `report-figures` (below), which reuses the same publication report.
PUBLICATION_BOOTSTRAP_SEED=42
PUBLICATION_BOOTSTRAP_RESAMPLES=2000

# Price summaries at batch (50%-off) rates instead of real-time in the cost
# columns. Leave false unless the summaries being reported were produced by the
# batch API (a summary slot does not record which path generated it).
PUBLICATION_COST_BATCHED=false

# `python llm-sum/run_phase3.py report-figures` renders four PNG/SVG figures
# (provider comparison, cost-quality Pareto, per-criterion heatmap, and — when
# a jury run exists — inter-judge reliability) and exports a named,
# taxonomy-keyed leaderboard (JSON + Markdown) to data/results/. Offline;
# reuses report_tables.py's publication report and, when
# data/human_reviews.jsonl exists (Phase 5), adds per-provider human-vs-jury
# correlation to the leaderboard automatically. See docs/phase6/reporting.md.
#   PUBLICATION_FIGURE_FORMATS=png,svg   # default — both formats, every figure
#   PUBLICATION_FIGURE_FORMATS=png       # smaller output, no vector copy
PUBLICATION_FIGURE_FORMATS=png,svg

# `python llm-sum/run_phase3.py stats-engine` (also folded automatically into
# `eval-report --publication`) computes information density (word count +
# TF-IDF/cosine similarity vs. the paper's abstract), Cohen's Kappa + percent
# agreement (LLM judge vs. human reviewer), subscription-based
# cost-per-quality, and provider x covariate (species/study_design/journal)
# tables. Offline; no API calls. See llm-sum/stats_engine.py and
# docs/statistics_explained.md.

# Consumer-economics cost-per-quality assumption: a veterinarian pays a flat
# monthly subscription, not per-token API pricing. Deliberately separate from
# the real API cost report_tables.py already tracks — both are reported side
# by side, neither replaces the other.
SUBSCRIPTION_COST_PER_MONTH_USD=20.0
# 20 papers/day x 25 days.
SUBSCRIPTION_PAPERS_PER_MONTH=500


