# ── Phase 2: Safety & Ingestion ──────────────────────────────────────────────
# Set DRY_RUN=true to run the full pipeline with mock data and no network calls.
# Set DRY_RUN=false when you are ready to query CrossRef and download real PDFs.
DRY_RUN=true

# Hard budget ceiling in USD.  BudgetGuard will call sys.exit() if total_spent
# exceeds this value.  Keep at 0.00 during Phase 2 (no LLM calls = $0 cost).
BUDGET_HARD_STOP=0.00

# Your institutional email address.  Required by Unpaywall and CrossRef polite
# pool.  This is NOT a secret — it just identifies you as a researcher.
UNPAYWALL_EMAIL=your.name@uoguelph.ca

# Number of CrossRef DOI candidates to collect per journal before downloading.
# Default 2000 = up to 10000 candidates total across the 5 target journals.
# The downloader still stops at 50 accepted PDFs per journal.
COLLECT_CANDIDATES_PER_JOURNAL=1000

# Query each year separately so the manifest covers all years evenly instead
# of filling only from the newest CrossRef results.
# Range: 2023–2026 (including the current year captures recent OA deposits).
COLLECT_YEAR_BALANCED=true
COLLECT_YEARS=2023,2024,2025,2026

# Optional: query Unpaywall during collection and add OA metadata/ranking fields
# to the manifest.  Leave strict mode false unless you want to exclude papers
# with no known OA locations before the downloader tries them.
COLLECT_PREFLIGHT_UNPAYWALL=false
COLLECT_REQUIRE_UNPAYWALL_OA=false
COLLECT_MIN_OA_LOCATIONS=1
COLLECT_PREFER_DIRECT_PDF=true

# Seconds to wait between API calls for each model (prevents HTTP 429 errors).
# Increase these values if you see rate-limit errors during Phase 3.
RATE_LIMIT_GEMINI=1.0
RATE_LIMIT_OPENAI=1.0
RATE_LIMIT_ANTHROPIC=1.0
RATE_LIMIT_DEFAULT=1.0

# OpenAI rate-limit retry config (applies only when HTTP 429 is received).
# The inner backoff layer retries up to MAX_RETRIES times before propagating.
# Formula: delay = min(BASE_DELAY * 2^attempt + jitter(0,1), MAX_DELAY)
# Increase MAX_RETRIES or MAX_DELAY if you are on a low tier with slow resets.
OPENAI_MAX_RETRIES=6
OPENAI_RETRY_BASE_DELAY=1.0
OPENAI_RETRY_MAX_DELAY=60.0

# ── Phase 2: Balanced Corpus Download Controls ───────────────────────────────
# Minimal output by default: progress bar + one line per success/failure only.
# Set DOWNLOAD_VERBOSE=true to also see "Trying OA sources for DOI: ..." and
# "Already exists, skipping" messages — useful when debugging a single paper.
# All failures are still written to data/error_log.jsonl regardless of this flag.
DOWNLOAD_VERBOSE=false

# Maximum number of failed download attempts allowed per journal before the
# journal is flagged for manual supplementation and skipped.
# Default 300 balances runtime vs coverage for large candidate manifests.
MAX_FAILED_PER_JOURNAL=300

# Per-journal Cloudflare / HTTP 403 tally (seeded from data/error_log.jsonl).
# When reached, remaining manifest rows skip automation with reason CLOUDFLARE_BLOCKED.
MANUAL_ONLY_THRESHOLD=10

# Seconds to pause between each OA fallback attempt for a single DOI.
# Prevents HTTP 429 rate-limit errors from Unpaywall, Semantic Scholar, and NCBI.
# Set to 0 if you are running off-campus and want maximum speed.
DOWNLOAD_DELAY_SECONDS=2

# Publisher-facing requests (Wiley, AVMA, SAGE) should be slower than API
# requests because they go through human-facing journal websites and CDN
# bot/rate-limit systems.  The downloader picks a random value in this range
# before each publisher request.  For single-DOI debugging, set both to 0.
PUBLISHER_DELAY_MIN_SECONDS=10
PUBLISHER_DELAY_MAX_SECONDS=25

# If a server returns HTTP 429 without a Retry-After header, wait this many
# seconds before continuing.  If Retry-After is provided, the script obeys it.
RATE_LIMIT_BACKOFF_SECONDS=60

# ── Phase 2: PDF Text Validation Gate ────────────────────────────────────────
# MIN_PAGES: reject short PDFs before full text extraction.
# MIN_SECTIONS: minimum count of matched section categories (introduction /
# methods / results / discussion / conclusion), each detected by synonym regex
# in SECTION_PATTERNS—not by matching one fixed header spelling.
# MIN_EXTRACTED_WORDS remains the hard final gate after references stripping.
MIN_PAGES=3
MIN_SECTIONS=3
MIN_EXTRACTED_WORDS=3000
TARGET_EXTRACTED_WORDS=4500
MIN_EXTRACTED_TOKENS=4000

# Phase 3 PDF text extraction. Leave true for two-column journals (JVIM, VRU):
# pdfplumber/pdfminer then follows text flow more carefully instead of
# interleaving left and right columns. If your installed pdfplumber is too old,
# the code logs a warning and falls back to tight character-based grouping.
PDFPLUMBER_USE_TEXT_FLOW=true

# Leave false for real runs.  Set true only in narrow unit tests that exercise
# downloader plumbing without constructing real PDFs.
SKIP_VALIDATION_FOR_TESTING=false

# ── Article-type filtering ────────────────────────────────────────────────────
# EXCLUDE_ARTICLE_TYPE_PATTERNS: comma-separated phrases that identify non-
# primary-research articles.  If any phrase appears in the first two pages of a
# downloaded PDF, the PDF is deleted and the DOI is logged as NON_RESEARCH_TYPE.
# These article types do NOT count toward the 50-paper per-journal quota.
#
# WHY CHECK THE PDF AND NOT JUST THE METADATA?
#   CrossRef often lacks structured article-type fields.  Veterinary journals
#   reliably print labels like "Short Communication" or "Case Report" at the top
#   of the first page, so reading the PDF is more reliable.
#
# COLLECT_EXCLUDE_TYPES (optional): the same phrases are also checked at
# collection time in collect.py.  If a CrossRef title begins with one of these
# phrases (e.g. "Case Report: Spontaneous X in a cat"), the DOI is excluded from
# manifest.jsonl entirely, saving a download attempt.
EXCLUDE_ARTICLE_TYPE_PATTERNS=short communication,brief communication,brief report,case report,case series,case study,imaging diagnosis,imaging findings,rapid communication

# SECONDARY_ARTICLE_TYPE_PATTERNS: phrases that identify secondary research
# (literature reviews, syntheses of existing studies).  These ARE downloaded but
# saved with a "2_" filename prefix so they are easy to find and can be excluded
# from LLM analysis if needed.  They do NOT count toward the primary-research quota.
#
# In pipeline.py, secondary papers are listed separately from primary papers so
# you always know your exact primary vs secondary breakdown.
SECONDARY_ARTICLE_TYPE_PATTERNS=systematic review,meta-analysis,scoping review,narrative review



# ── Phase 3: Summariser & Judge Configuration ────────────────────────────────
# Paths to the summarisation prompt and optional human-written format guide
# (relative to repo root).  PROMPT_MODE=shared keeps the study baseline fair:
# OpenAI, Anthropic, and Gemini all receive the same prompt.  Switch to
# PROMPT_MODE=provider_specific only for prompt-engineering experiments where
# you intentionally want to edit one provider's instructions without changing
# the others.  Every prompt file must keep the {ARTICLE_TEXT} placeholder.
PROMPT_MODE=shared
PROMPT_FILE=llm-sum/prompts/summarization_v1.txt
OPENAI_PROMPT_FILE=llm-sum/prompts/summarization_openai_v1.txt
ANTHROPIC_PROMPT_FILE=llm-sum/prompts/summarization_anthropic_v1.txt
GEMINI_PROMPT_FILE=llm-sum/prompts/summarization_gemini_v1.txt
GUIDE_SUMMARY_FILE=llm-sum/prompts/guide_summary_template.txt
# Phase 3.5: switched to vet-specific rubric (4 weighted dimensions, source-quoting hallucinations).
# Set back to judge_v1.txt to revert to the generic 1-10 rubric for any prior runs.
JUDGE_PROMPT_FILE=llm-sum/prompts/judge_v2.txt

# ── Phase 3: Run mode ────────────────────────────────────────────────────────
# PHASE3_MODE is the single knob controlling what summarizer/evaluator do.
# Pick one and the rest of the behaviour follows automatically.
#
#   test     DRY_RUN, no API calls, mock data. Default. Used by pytest.
#            Safe to leave here forever; no spend possible.
#   single   1 matched article, real-time API. For summarize-all this means:
#            the same DOI/title from data/raw and data/processed:
#            1 raw PDF x 3 providers + 1 processed text x 3 providers
#            = 6 summaries total. Use this as the paid smoke test.
#   dev      PHASE3_DEV_LIMIT papers (default 5), real-time, budget-guarded.
#            For summarize-all, dev also defaults to the same 1 matched
#            DOI/title pair as single, producing 6 summaries total unless
#            you explicitly pass --limit N.
#   batch    Full corpus, Batch API (50% off where supported). Requires
#            interactive 'yes' confirmation at the prompt. Note:
#            summarize-all does not support batch because direct PDF upload
#            is real-time only; use batch only for manifest/text workflows.
#
# CLI --mode and --limit on any Phase 3 script override these values per run.
PHASE3_MODE=test
PHASE3_DEV_LIMIT=5

# summarize-all comparison workflow controls.
# SUMMARIZE_ALL_RANDOM_MATCH=true picks matched PDF/processed article pairs
# randomly. Set false to pick the same first sorted matched article(s) every run.
# SUMMARIZE_ALL_UNIQUE_OUTPUT=true writes separate timestamped files on each run:
#   data/summaries_pdf/<stem>__run_YYYYMMDDTHHMMSSffffffZ.txt
#   data/summaries_txt/<stem>__run_YYYYMMDDTHHMMSSffffffZ.txt
# Set false to write data/summaries_pdf/<stem>.txt and
# data/summaries_txt/<stem>.txt, which can overwrite earlier outputs.
SUMMARIZE_ALL_RANDOM_MATCH=false
SUMMARIZE_ALL_UNIQUE_OUTPUT=true

# Per-provider batch availability (only consulted when PHASE3_MODE=batch).
# Gemini batch is intentionally off — its non-batch API is fast enough that
# the marginal saving isn't worth the second code path.
OPENAI_BATCH_ENABLED=true
ANTHROPIC_BATCH_ENABLED=true
GEMINI_BATCH_ENABLED=false

# Scientific controls — DO NOT CHANGE between runs you want to compare.
TEMPERATURE=0.0
SEED=42
# MAX_INPUT_CHARS applies only to pasted text inputs from data/processed/ and
# data/raw_text/. Direct PDF uploads from data/raw/ are not truncated here.
# Set 0 to send the full cached text; use 12000 to cap costs during debugging.
MAX_INPUT_CHARS=12000
# Shared output-token cap for summariser, batch, judge, and cost-estimator calls.
# 1500 leaves room for structured summaries and judge_v2 source-quote responses.
# Keep this fixed between runs you want to compare.
MAX_OUTPUT_TOKENS=1500

# Judge configuration.
# JUDGE_MODELS: comma-separated list of summariser keys to use as judges.
# Default single judge keeps cost low; set "openai,anthropic" for double-judge.
JUDGE_MODELS=openai

# Phase 3.5: Journal-stratified evaluation sampling seed.
# Fixed seed ensures the same 5 articles (1 per journal) are always selected
# in single/dev mode, making runs reproducible and auditable.
# Change only if you intentionally want a different random draw.
EVAL_SAMPLE_SEED=42

# Model IDs used for Phase 3 summarisation/evaluation.
#
# HOW THE CLIENTS WORK:
#   The Python code loads this .env file once at startup, then creates provider
#   clients only when that provider is actually called:
#
#     OpenAI    -> openai.OpenAI()
#     Anthropic -> anthropic.Anthropic()
#     Gemini    -> google.genai.Client()
#
#   The model IDs below are then read with os.getenv(...) and passed to those
#   clients. Keeping model names here instead of hardcoding them in Python makes
#   it easy to update models without editing the pipeline logic.
#
# These must be the exact API model identifiers accepted by each provider.
# Requested lineup:
#   OpenAI    = ChatGPT/GPT 5.4
#   Anthropic = Claude Sonnet 4.6
#   Gemini    = Gemini 3.5 Flash
OPENAI_MODEL=gpt-5.4
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-3.5-flash

# ── Phase 3: LLM Summarisation (fill in when API keys are available) ──────────
# API keys are secrets. Put real keys in .env only. Do not commit .env.
# GEMINI_API_KEY=YOUR_KEY_HERE
# ANTHROPIC_API_KEY=YOUR_KEY_HERE
# OPENAI_API_KEY=YOUR_KEY_HERE