# ── Phase 2: Safety & Ingestion ──────────────────────────────────────────────
# Set DRY_RUN=true to run the full pipeline with mock data and no network calls.
# Set DRY_RUN=false when you are ready to query CrossRef and download real PDFs.
DRY_RUN=true

# Hard budget ceiling in USD.  BudgetGuard will call sys.exit() if total_spent
# exceeds this value.  Keep at 0.00 during Phase 2 (no LLM calls = $0 cost).
BUDGET_HARD_STOP=0.00

# Your institutional email address.  Required by Unpaywall and CrossRef polite
# pool.  This is NOT a secret — it just identifies you as a researcher.
UNPAYWALL_EMAIL=your.name@uoguelph.ca

# Seconds to wait between API calls for each model (prevents HTTP 429 errors).
# Increase these values if you see rate-limit errors during Phase 3.
RATE_LIMIT_GEMINI=1.0
RATE_LIMIT_OPENAI=1.0
RATE_LIMIT_ANTHROPIC=1.0
RATE_LIMIT_DEFAULT=1.0

# ── Phase 2: Balanced Corpus Download Controls ───────────────────────────────
# Minimal output by default: progress bar + one line per success/failure only.
# Set DOWNLOAD_VERBOSE=true to also see "Trying OA sources for DOI: ..." and
# "Already exists, skipping" messages — useful when debugging a single paper.
# All failures are still written to data/error_log.jsonl regardless of this flag.
DOWNLOAD_VERBOSE=false

# Maximum number of failed download attempts allowed per journal before the
# journal is flagged for manual supplementation and skipped.
# Default 100 = effectively "exhaust all 80 candidates" (1.25 x the pool).
# Lower to e.g. 40 to save time at the cost of potentially missing late-pool OA papers.
MAX_FAILED_PER_JOURNAL=100

# Seconds to pause between each OA fallback attempt for a single DOI.
# Prevents HTTP 429 rate-limit errors from Unpaywall, Semantic Scholar, and NCBI.
# Set to 0 if you are running off-campus and want maximum speed.
DOWNLOAD_DELAY_SECONDS=2

# Publisher-facing requests (Wiley, AVMA, SAGE) should be slower than API
# requests because they go through human-facing journal websites and CDN
# bot/rate-limit systems.  The downloader picks a random value in this range
# before each publisher request.  For single-DOI debugging, set both to 0.
PUBLISHER_DELAY_MIN_SECONDS=10
PUBLISHER_DELAY_MAX_SECONDS=25

# If a server returns HTTP 429 without a Retry-After header, wait this many
# seconds before continuing.  If Retry-After is provided, the script obeys it.
RATE_LIMIT_BACKOFF_SECONDS=60

